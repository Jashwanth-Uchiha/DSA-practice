//perplexity's code below
#include <iostream>
using namespace std;

int peak(int nums[], int n, int size) {
    if (n == 0) {
        if (size == 1 || nums[0] > nums[1]) return 0;
        return peak(nums, n + 1, size);
    }

    if (n == size - 1) {
        if (nums[n] > nums[n - 1]) return n;
        return -1;
    }

    if (nums[n] > nums[n - 1] && nums[n] > nums[n + 1]) {
        return n;
    }

    return peak(nums, n + 1, size);
}

int main() {
    int arr[] = {1, 2, 4, 3, 5, 6, 7, 78, 9};
    int size = sizeof(arr) / sizeof(arr[0]);

    int k = peak(arr, 0, size);
    if (k != -1) cout << arr[k] << endl;
    return 0;
}